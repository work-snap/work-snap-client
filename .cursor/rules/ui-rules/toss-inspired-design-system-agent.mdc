  ```tsx
  // ✅ Good: Proper folder architecture and component organization
  
  // File: src/app/user-dashboard/page.tsx
  "use client";
  import { useState } from 'react';
  import { TabType } from './lib/types';
  import { useUserState, useLoadingState } from './lib/hooks';
  import { 
    UserProfile, 
    UserSettings, 
    TabNavigation,
    ProfileTab,
    SettingsTab 
  } from './components';
  
  export default function UserDashboardPage() {
    const [activeTab, setActiveTab] = useState<TabType>('profile');
    const { userProfile, updateProfile } = useUserState();
    const { loading, setLoadingState } = useLoadingState();
    
    return (
      <div className="min-h-screen bg-toss-gray-50 p-toss-lg">
        <div className="max-w-7xl mx-auto">
          <div className="bg-white shadow-toss-card rounded-toss-lg p-toss-xl">
            <h1 className="text-toss-headline font-toss text-toss-navy mb-toss-lg">
              User Dashboard
            </h1>
            
            <TabNavigation activeTab={activeTab} onTabChange={setActiveTab} />
            
            {activeTab === 'profile' && (
              <ProfileTab 
                profile={userProfile}
                loading={loading}
                onUpdate={updateProfile}
                onLoadingChange={setLoadingState}
              />
            )}
          </div>
        </div>
      </div>
    );
  }
  
  // File: src/app/user-dashboard/lib/types.ts
  export interface UserProfile {
    id: string;
    name: string;
    email: string;
    avatar?: string;
  }
  
  export type TabType = 'profile' | 'settings' | 'billing';
  
  export interface LoadingState {
    profile: boolean;
    settings: boolean;
  }
  
  // File: src/app/user-dashboard/components/index.ts
  export { UserProfile } from './UserProfile';
  export { TabNavigation } from './TabNavigation';
  export { ProfileTab } from './tabs/ProfileTab';
  export { SettingsTab } from './tabs/SettingsTab';
  ```
